@model IEnumerable<HCM.Models.Models.Candidate>

@{
    ViewData["Title"] = "Candidates";
}

<h2 class="mb-4">Candidate Applications</h2>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Skills</th>
            <th>Interview Date</th>
            <th>Interviewer</th>
            <th>Job</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var candidate in Model)
        {
            <tr>
                <td>@candidate.CadidateName</td>
                <td>@candidate.SkillSets</td>
                <td>@candidate.InterviewDate</td>
                <td>@candidate.Interviewer</td>
                <td>@candidate.Jobs?.JobName</td>
                <td>
                    @if (candidate.IsSelected == true)
                    {
                        <span class="badge bg-success">Selected</span>
                    }
                    else if (candidate.IsUnattended == true)
                    {
                        <span class="badge bg-warning text-dark">Unattended</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pending</span>
                    }
                </td>
                <td>
                    <a asp-action="Upsert" asp-route-id="@candidate.CandidateId" class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>

                    <a asp-action="Details" asp-route-id="@candidate.CandidateId" class="btn btn-sm btn-info text-white">
                        <i class="bi bi-eye"></i> View
                    </a>

                    <!-- Delete Button Trigger -->
                    <button class="btn btn-sm btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"
                            data-id="@candidate.CandidateId"
                            data-name="@candidate.CadidateName">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="UpSert" class="btn btn-primary mt-3">
    <i class="bi bi-plus-circle"></i> Create New Profile
</a>

<!-- DELETE CONFIRMATION MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0" style="border-radius: 12px;">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p class="fw-bold text-danger mb-1">Are you sure?</p>
                <p class="text-muted mb-0">
                    You are about to delete <span id="candidateName" class="fw-semibold"></span>.
                    This action cannot be undone.
                </p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>

                <form id="deleteForm" method="post">
                    <button type="submit" class="btn btn-danger px-4">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');

        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;

            const id = button.getAttribute('data-id');
            const name = button.getAttribute('data-name');

            document.getElementById('candidateName').textContent = name;

            const form = document.getElementById('deleteForm');
            form.action = `/Candidate/Delete/${id}`;
        });
    </script>
}