@model HCM.Models.ViewModels.CandidateVM

@{
    ViewData["Title"] = "Candidate Details";
}

<h2 class="mb-4 text-center text-primary fw-bold">Candidate Details</h2>

<div class="card detail-card shadow-lg border-0">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3 fw-semibold">Name</dt>
            <dd class="col-sm-9">@Model.Candidate.CadidateName</dd>

            <dt class="col-sm-3 fw-semibold">Skill Sets</dt>
            <dd class="col-sm-9">@Model.Candidate.SkillSets</dd>

            <dt class="col-sm-3 fw-semibold">Interview Date</dt>
            <dd class="col-sm-9">@Model.Candidate.InterviewDate.ToString("dd-MMM-yyyy")</dd>

            <dt class="col-sm-3 fw-semibold">Interviewer</dt>
            <dd class="col-sm-9">@Model.Candidate.Interviewer</dd>

            <dt class="col-sm-3 fw-semibold">Job Description</dt>
            <dd class="col-sm-9">@Model.Candidate.JobDescription</dd>

            <dt class="col-sm-3 fw-semibold">Job Category</dt>
            <dd class="col-sm-9">@Model.Candidate.Jobs?.JobName</dd>

            <dt class="col-sm-3 fw-semibold">Previously Attended</dt>
            <dd class="col-sm-9">
                @(Model.Candidate?.IsPreviouslyAttended == true ? "Yes"
                                : Model.Candidate?.IsPreviouslyAttended == false ? "No"
                                : "Not Specified")
            </dd>

            <dt class="col-sm-3 fw-semibold">Unattended</dt>
            <dd class="col-sm-9">
                @(Model.Candidate?.IsUnattended == true ? "Yes"
                                : Model.Candidate?.IsUnattended == false ? "No"
                                : "Not Specified")
            </dd>
        </dl>
    </div>
</div>

<div class="mt-4 text-center">
    <a asp-action="Upsert" asp-route-id="@Model.Candidate.CandidateId" class="btn btn-warning me-2">
        <i class="bi bi-pencil-square"></i> Edit Profile
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>


    <style>
        body {
            background: #f9f9fb;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        h2 {
            color: #4a6fa5;
        }

        .detail-card {
            background: linear-gradient(135deg, #ffffff, #f0f4ff);
            border-radius: 12px;
            padding: 20px;
        }

        dt {
            color: #4a4a4a;
        }

        dd {
            color: #2c3e50;
            margin-bottom: 12px;
        }

        .btn-warning {
            background-color: #f7b731;
            border: none;
            font-weight: 600;
        }

            .btn-warning:hover {
                background-color: #e0a800;
            }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
            font-weight: 600;
        }

            .btn-secondary:hover {
                background-color: #5a6268;
            }
    </style>
