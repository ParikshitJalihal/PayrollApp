@model List<HCM.Models.Models.PayComponent>

@{
    ViewData["Title"] = "Pay Components";
}

<div class="container mt-4">
    <h2 class="text-primary fw-semibold mb-3">
        <i class="bi bi-cash-stack me-2"></i> Pay Components
    </h2>
    <hr />

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i> Add New Component
        </a>
    </div>

    <table class="table table-hover table-bordered align-middle shadow-sm">
        <thead class="table-light">
            <tr>
                <th>Component Name</th>
                <th>Type</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ComponentName</td>
                    <td>
                        <span class="badge @(item.ComponentType == "Earning" ? "bg-success" : "bg-danger")">
                            @item.ComponentType
                        </span>
                    </td>
              
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.PayComponentId" class="btn btn-sm btn-outline-primary me-1">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.PayComponentId" class="btn btn-sm btn-outline-info me-1">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.PayComponentId" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
