<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Job Name</th>
            <th>Status</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var job in Model)
        {
            <tr>
                <td>@job.JobName</td>
                <td>
                    @if (job.JobStatus)
                    {
                        <span class="badge bg-success">Open</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Closed</span>
                    }
                </td>
                <td>@job.JobStatusDescription</td>
                <td>
                    <a asp-action="Upsert" asp-route-id="@job.JobId" class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    @* <a asp-action="Delete" asp-route-id="@job.JobId" class="btn btn-sm btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </a> *@
                    <button class="btn btn-sm btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"
                            data-id="@job.JobId"
                            data-name="@job.JobName">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
    
</table>
<a asp-action="UpSert" class="btn btn-primary mt-3">
    <i class="bi bi-plus-circle"></i> Create New Postion
</a>
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0" style="border-radius: 12px;">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p class="fw-bold text-danger mb-1">Are you sure?</p>
                <p class="text-muted mb-0">
                    You are about to delete <span id="candidateName" class="fw-semibold"></span>.
                    This action cannot be undone.
                </p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>

                <form id="deleteForm" method="post">
                    <button type="submit" class="btn btn-danger px-4">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');

        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;

            const id = button.getAttribute('data-id');
            const name = button.getAttribute('data-name');

            document.getElementById('candidateName').textContent = name;

            const form = document.getElementById('deleteForm');
            form.action = `/Jobs/Delete/${id}`;
        });
    </script>
}