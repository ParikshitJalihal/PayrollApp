@model IEnumerable<HCM.Models.Models.RequisiteDetails>

@{
    ViewData["Title"] = "Masters";
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold mb-3">Masters List</h2>

    <div class="mb-3">
        <a asp-action="CreateMaster" class="btn btn-success fw-semibold">
            <i class="bi bi-plus-circle me-1"></i> Create New Master
        </a>
    </div>

    <table class="table table-bordered table-striped shadow-sm">
        <thead class="table-light">
            <tr>
                <th>Type</th>
                <th>Name</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Requesites?.ReqName</td>
                        <td>@item.RequisiteValue</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.RequisiteDetailsId" class="btn btn-sm btn-primary me-1">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.RequisiteDetailsId" class="btn btn-sm btn-danger"
                               onclick="return confirm('Are you sure you want to delete this master?');">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No masters found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
