@model List<HCM.Models.ViewModels.EmployeeVM>

@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Employees</h2>
    <div>
        <a asp-area="Admin" asp-controller="Employee" asp-action="UpSert" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Create Employee
        </a>
    </div>
</div>

<div class="mb-3">
    <input id="search" class="form-control" placeholder="Search by name, code, email, job..." oninput="filterTable()" />
</div>

<table id="employeesTable" class="table table-striped table-hover">
    <thead class="table-light">
        <tr>
            <th>#</th>
            <th>Code</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Job</th>
            <th>Department</th>
            <th>Joining Date</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            var idx = 1;
            foreach (var item in Model)
            {
                <tr>
                    <td>@idx</td>
                    <td>@(item.EmployeeCode ?? "—")</td>
                    <td>@item.EmployeeName</td>
                    <td>@(item.EmployeeEmail ?? "—")</td>
                    <td>@(item.EmployeePhone ?? "—")</td>
                    <td>@(item.JobName ?? "—")</td>
                    <td>@(item.DepartmentName ?? "—")</td>
                    <td>@(item.Employee.JoiningDate == default ? "—" : item.Employee.JoiningDate.ToString("yyyy-MM-dd"))</td>
                    <td class="text-center">
                        <a asp-area="Admin" asp-controller="Employee" asp-action="UpSert" asp-route-id="@item.Employee.EmployeeId" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <a asp-area="Admin" asp-controller="Employee" asp-action="Details" asp-route-id="@item.Employee.EmployeeId" class="btn btn-sm btn-outline-info me-1" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        <form asp-area="Admin" asp-controller="Employee" asp-action="Delete" asp-route-id="@item.Employee.EmployeeId" method="post" class="d-inline" onsubmit="return confirm('Delete employee?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                idx++;
            }
        }
    </tbody>
</table>

@section Scripts {
    <script>
        function filterTable() {
            var q = document.getElementById('search').value.toLowerCase().trim();
            document.querySelectorAll('#employeesTable tbody tr').forEach(function (tr) {
                tr.style.display = q === '' || tr.innerText.toLowerCase().indexOf(q) !== -1 ? '' : 'none';
            });
        }
    </script>
}