@model HCM.Models.Models.Account

@{
    ViewData["Title"] = "Create Account";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-light">
            <h3 class="text-primary mb-0">Create New Account</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div class="mb-3">
                    <label asp-for="AccountName" class="form-label text-muted"></label>
                    <input asp-for="AccountName" class="form-control shadow-sm" placeholder="Enter account name" />
                    <span asp-validation-for="AccountName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AccountType" class="form-label text-muted"></label>
                    <select asp-for="AccountType" class="form-select shadow-sm">
                        <option value="">-- Select Type --</option>
                        <option>Asset</option>
                        <option>Liability</option>
                        <option>Expense</option>
                        <option>Revenue</option>
                    </select>
                    <span asp-validation-for="AccountType" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-success px-4 shadow-sm">
                        <i class="bi bi-check-circle"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
